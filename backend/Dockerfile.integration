FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY src/ ./src/
COPY tests/ ./tests/
COPY pytest.ini ./pytest.ini
RUN mkdir -p /app/storage
ENV PYTHONUNBUFFERED=1
ENV ENV=test
CMD ["python", "-m", "pytest", "-o", "addopts=", "tests/integration", "-m", "integration", "-v", "--strict-markers", "--tb=short", "--asyncio-mode=auto", "--cov=src", "--cov-report=term-missing", "--cov-report=term"]
